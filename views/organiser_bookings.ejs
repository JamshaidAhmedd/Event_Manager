<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>All Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/css/app.min.css" rel="stylesheet">
  <link href="/main.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/">Event Manager</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/organiser">Dashboard</a>
        <a class="nav-link" href="/attendee">Events</a>
      </div>
    </div>
  </nav>
  <div class="wrapper">
    <nav id="sidebar" class="sidebar js-sidebar">
      <a class="sidebar-brand" href="/organiser">
        <span class="align-middle">Organiser</span>
      </a>
      <ul class="sidebar-nav">
        <li class="sidebar-item"><a class="sidebar-link" href="/organiser">Dashboard</a></li>
        <li class="sidebar-item"><a class="sidebar-link" href="/organiser/settings">Settings</a></li>
        <li class="sidebar-item"><a class="sidebar-link" href="/organiser/bookings">Bookings</a></li>
        <li class="sidebar-item"><a class="sidebar-link" href="/organiser/logout">Logout</a></li>
      </ul>
    </nav>
    <div class="main">
      <nav class="navbar navbar-expand navbar-light navbar-bg">
        <a class="sidebar-toggle js-sidebar-toggle">
          <i class="hamburger align-self-center"></i>
        </a>
      </nav>
      <main class="content">
        <div class="container-fluid p-0">
    <h1 class="mb-4">All Bookings</h1>
    <% if (bookings.length === 0) { %>
      <p>No bookings have been made yet.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>ID</th>
              <th>Event Title</th>
              <th>Event Date</th>
              <th>Attendee Name</th>
              <th>Full Tickets</th>
              <th>Concession Tickets</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b) { %>
              <tr>
                <td><%= b.booking_id %></td>
                <td><%= b.title %></td>
                <td><%= b.event_date %></td>
                <td><%= b.name %></td>
                <td><%= b.full_count %></td>
                <td><%= b.concession_count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <a href="/organiser" class="btn btn-secondary mt-3">Back to Home</a>
        </div>
      </main>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/js/app.min.js"></script>
</body>
</html>
