<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>All Bookings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/main.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">
    <!-- Nav bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
      <div class="container-fluid">
        <a class="navbar-brand" href="/organiser">Organiser</a>
        <div class="navbar-nav">
          <a class="nav-link" href="/organiser/settings">Site Settings</a>
          <a class="nav-link active" href="/organiser/bookings">All Bookings</a>
          <a class="nav-link" href="/organiser/logout">Logout</a>
        </div>
      </div>
    </nav>
    <h1 class="mb-4">All Bookings</h1>
    <% if (bookings.length === 0) { %>
      <p>No bookings have been made yet.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>Event Title</th>
              <th>Event Date</th>
              <th>Attendee Name</th>
              <th>Full Tickets</th>
              <th>Concession Tickets</th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(function(b) { %>
              <tr>
                <td><%= b.title %></td>
                <td><%= b.event_date %></td>
                <td><%= b.name %></td>
                <td><%= b.full_count %></td>
                <td><%= b.concession_count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
    <a href="/organiser" class="btn btn-secondary mt-3">Back to Home</a>
  </div>
</body>
</html>
