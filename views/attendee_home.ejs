<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Attendee Home</title>
  <link href="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/css/app.min.css" rel="stylesheet">
  <link href="/main.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">
    <h1 class="mb-3">Attendee Home Page</h1>
    <!-- Display site name and description -->
    <h2><%= siteName %></h2>
    <p><%= siteDescription %></p>
    <!-- List of upcoming events -->
    <% if (events.length === 0) { %>
      <p class="fst-italic">No events available at this time.</p>
    <% } else { %>
      <div class="list-group mt-3">
        <% events.forEach(function(ev) { %>
          <a href="/attendee/event/<%= ev.event_id %>" 
             class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
            <div>
              <strong><%= ev.title %></strong> – <%= ev.event_date %>
            </div>
            <% if (typeof ev.totalRemaining !== 'undefined') { %>
              <% if (ev.totalRemaining === 0) { %>
                <span class="badge bg-danger">Sold Out</span>
              <% } else { %>
                <span class="badge bg-primary"><%= ev.totalRemaining %> tickets left</span>
              <% } %>
            <% } %>
          </a>
        <% }) %>
      </div>
    <% } %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/js/app.min.js"></script>
</body>
</html>
