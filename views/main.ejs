<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Event Manager</title>
    <link
      href="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/css/app.min.css"
      rel="stylesheet"
    />
    <link href="/main.css" rel="stylesheet" />
  </head>
  <body>
    <header class="hero">
      <!-- Background with blur effect -->
      <div class="hero-background"></div>

      <!-- Content layer above the blur -->
      <div class="hero-content text-center">
        <h1 class="display-4 mb-3">Event Manager</h1>
        <p class="lead mb-4">Manage and book amazing events with ease</p>
        <div class="cta-buttons">
          <a href="/organiser" class="btn btn-primary btn-lg mx-2"
            >Organiser Section</a
          >
          <a href="/attendee" class="btn btn-success btn-lg mx-2"
            >Attendee Section</a
          >
        </div>
      </div>
    </header>
    <script src="https://cdn.jsdelivr.net/npm/@adminkit/core@3.0.0/dist/js/app.min.js"></script>
  </body>
</html>
